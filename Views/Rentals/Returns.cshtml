@model IEnumerable<meow.Models.Wypozyczenie>
@{
ViewData["Title"] = Localizer["Rentals_Title"];

var rezerwacje = Model.Where(w => w.IdEgzemplarz != null && w.DataZwrotu == null && w.DataPlanowanegoZwrotu <= w.DataWypozyczenia.AddDays(3)).ToList();

var wydane = Model.Where(w => w.IdEgzemplarz != null && w.DataZwrotu == null && w.DataPlanowanegoZwrotu > w.DataWypozyczenia.AddDays(3)).ToList();
}

<style>
    .rentals-box { background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 20px; font-family: sans-serif; }
    .r-table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 35px; }
    .r-table th { background: #f8fafc; color: #234465; text-align: left; padding: 14px; font-weight: bold; border-bottom: 2px solid #e2e8f0; }
    .r-table td { padding: 14px; border-bottom: 1px solid #f1f5f9; font-size: 14px; }
    .btn-action { background: #234465; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 12px; }
    .btn-action:hover { background: #1a3047; }
    .btn-deliver { background: #16a34a; color: white; border: none; padding: 6px 15px; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 12px; }
    .btn-deliver:hover { background: #115e59; }
    .btn-shop-ship { background: #ff5a00; color: white; border: none; padding: 6px 15px; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 12px; }
    .btn-shop-ship:hover { background: #d04900; }
    .btn-details-admin { background: #7f8c8d; color: white; border: none; padding: 6px 12px; border-radius: 4px; font-size: 12px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
    .btn-details-admin:hover { background: #6c7a7d; }
    .badge { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; }
    .badge-progress { background: #fff7ed; color: #c2410c; border: 1px solid #fdba74; }
    .badge-success { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
</style>

<div class="rentals-box">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <h2 style="color: #234465; font-size: 26px; font-weight: bold; margin: 0;">@Localizer["Rentals_Title"]</h2>
        <a href="/Rentals/Create" style="background: #f1c40f; color: #234465; text-decoration: none; padding: 10px 20px; font-weight: bold; border-radius: 4px; font-size: 14px;">@Localizer["Rentals_NewIssue"]</a>
    </div>

    @if (TempData["Message"] != null)
    {
    var msgType = TempData["MessageType"]?.ToString();
    var bgColor = msgType == "success" ? "#dcfce7" : "#fee2e2";
    var textColor = msgType == "success" ? "#15803d" : "#ef4444";
    <div style="padding: 12px; background: @bgColor; color: @textColor; border-radius: 4px; margin: 20px 0; font-weight: 500;">
        @TempData["Message"]
    </div>
    }

    <h3 style="color: #e67e22; font-size: 18px; margin-top: 25px; font-weight: bold; border-bottom: 2px solid #f1f5f9; padding-bottom: 5px;">@Localizer["Rentals_ReservationsTitle"]</h3>
    <table class="r-table">
        <thead>
        <tr>
            <th>@Localizer["Rentals_ColReader"]</th>
            <th>@Localizer["Rentals_ColBook"]</th>
            <th style="text-align: center;">@Localizer["Rentals_ColInventory"]</th>
            <th>@Localizer["Rentals_ColReserveDate"]</th>
            <th>@Localizer["Rentals_ColPickupDeadline"]</th>
            <th style="text-align: center;">@Localizer["Rentals_ColActionStatus"]</th>
        </tr>
        </thead>
        <tbody>
        @if(rezerwacje.Any())
        {
        foreach (var item in rezerwacje)
        {
        <tr>
            <td style="font-weight: 600; color: #334155;">@(item.Klient != null ? $"{item.Klient.Nazwisko} {item.Klient.Imie}" : Localizer["Rentals_FallbackClient"].Value)</td>
            <td>@(item.Egzemplarz?.Book?.Tytul ?? Localizer["Common_NoData"].Value)</td>
            <td style="text-align: center; font-family: monospace; font-weight: bold;">#@(item.Egzemplarz?.NumerInwentarzowy ?? "-")</td>
            <td>@item.DataWypozyczenia.ToString("dd.MM.yyyy")</td>
            <td>
                        <span style="@(DateTime.Today > item.DataPlanowanegoZwrotu ? "color: #ef4444; font-weight: bold;" : "color: #e67e22; font-weight: bold;")">
                            @item.DataPlanowanegoZwrotu.ToString("dd.MM.yyyy") @Localizer["Rentals_Reserved"]
                        </span>
            </td>
            <td style="text-align: center;">
                <form action="/Rentals/ZatwierdzOdbior" method="post" style="margin: 0;">
                    <input type="hidden" name="id_wypozyczenie" value="@item.IdWypozyczenie" />
                    <button type="submit" class="btn-deliver">@Localizer["Rentals_IssueBtn"]</button>
                </form>
            </td>
        </tr>
        }
        }
        else
        {
        <tr><td colspan="6" style="text-align: center; padding: 20px; color: #94a3b8;">@Localizer["Rentals_NoReservations"]</td></tr>
        }
        </tbody>
    </table>

    <h3 style="color: #ff5a00; font-size: 18px; font-weight: bold; border-bottom: 2px solid #f1f5f9; padding-bottom: 5px;">@Localizer["Rentals_ShopOrdersTitle"]</h3>
    <table class="r-table">
        <thead>
        <tr>
            <th>@Localizer["Rentals_ColCustomer"]</th>
            <th>@Localizer["Rentals_ColContact"]</th>
            <th>@Localizer["Rentals_ColOrderDate"]</th>
            <th>@Localizer["Profile_ColValue"]</th>
            <th>@Localizer["Rentals_ColShipmentStatus"]</th>
            <th style="text-align: center;">@Localizer["Rentals_ColExpedition"]</th>
        </tr>
        </thead>
        <tbody>
        @if (ViewBag.ZamowieniaSklepowe != null && ((IEnumerable<dynamic>)ViewBag.ZamowieniaSklepowe).Any())
        {
        foreach (var order in ViewBag.ZamowieniaSklepowe)
        {
        <tr style="font-size: 14px;">
            <td style="font-weight: 600; color: #334155;">@order.KlientNazwa</td>
            <td style="color: #64748b; font-size: 12px; line-height: 1.3;">
                ✉ @order.KlientEmail <br />
                📞 @order.KlientTelefon
            </td>
            <td>@order.DataZlozenia</td>
            <td style="font-weight: bold; color: #234465;">@order.WartoscZamowienia.ToString("F2") @Localizer["Common_Currency"]</td>
            <td>
                @if (order.Status == "W przygotowaniu" || order.Status == "Nowe")
                {
                <span class="badge badge-progress">⏳ @meow.Services.LocalizationHelper.OrderStatus(Localizer, order.Status)</span>
                }
                else
                {
                <span class="badge badge-success">🚀 @meow.Services.LocalizationHelper.OrderStatus(Localizer, order.Status)</span>
                }
            </td>
            <td style="text-align: center;">
                <div style="display: flex; gap: 8px; justify-content: center; align-items: center;">
                    <button type="button" class="btn-details-admin" onclick="toggleAdminOrder('admin-order-@order.OrderId')">
                        @Localizer["Rentals_BtnContents"]
                    </button>

                    @if (order.Status == "W przygotowaniu" || order.Status == "Nowe")
                    {
                    <form action="/Rentals/ZatwierdzWysylke" method="post" style="margin: 0;">
                        <input type="hidden" name="trackingNumber" value="@order.TrackingNumber" />
                        <button type="submit" class="btn-shop-ship">@Localizer["Rentals_BtnShip"]</button>
                    </form>
                    }
                    else
                    {
                    <span style="font-size: 12px; color: #94a3b8; font-weight: 500;">@Localizer["Rentals_Completed"]</span>
                    }
                </div>
            </td>
        </tr>

        <tr id="admin-order-@order.OrderId" style="display: none; background-color: #f8fafc; border-bottom: 1px solid #cbd5e1;">
            <td colspan="6" style="padding: 15px 25px; text-align: left;">
                <div style="background: white; padding: 15px; border-radius: 6px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); border-left: 4px solid #ff5a00;">
                    <div style="font-size: 12px; color: #64748b; margin-bottom: 10px;">
                        @Localizer["Rentals_PackageNumber"] <code style="background: #f1f5f9; padding: 2px 5px; border-radius: 4px; color: #0f172a; font-weight: bold;">@order.TrackingNumber</code>
                    </div>
                    <div style="font-weight: bold; color: #234465; font-size: 13px; margin-bottom: 8px;">@Localizer["Rentals_PickList"]</div>
                    <ul style="margin: 0; padding-left: 20px; font-size: 13px; color: #334155; line-height: 1.6;">
                        @foreach (var item in order.SzczegolyPozycji)
                        {
                        <li>
                            <strong>@item.Tytul</strong> @Localizer["Rentals_ItemAuthor"] @item.Autor
                            <span style="margin-left: 15px; color: #64748b;">(@Localizer["Rentals_ItemQty"] <strong style="color: #0f172a;">@item.Ilosc @Localizer["Common_Pcs"]</strong>, @Localizer["Rentals_ItemValue"] @item.Cena.ToString("F2") @Localizer["Common_Currency"])</span>
                        </li>
                        }
                    </ul>
                </div>
            </td>
        </tr>
        }
        }
        else
        {
        <tr><td colspan="6" style="text-align: center; padding: 20px; color: #94a3b8;">@Localizer["Rentals_NoShopOrders"]</td></tr>
        }
        </tbody>
    </table>

    <h3 style="color: #234465; font-size: 18px; font-weight: bold; border-bottom: 2px solid #f1f5f9; padding-bottom: 5px;">@Localizer["Rentals_ActiveTitle"]</h3>
    <table class="r-table">
        <thead>
        <tr>
            <th>@Localizer["Rentals_ColReader"]</th>
            <th>@Localizer["Rentals_ColBook"]</th>
            <th style="text-align: center;">@Localizer["Rentals_ColInventory"]</th>
            <th>@Localizer["Rentals_ColIssueDate"]</th>
            <th>@Localizer["Rentals_ColDueDate"]</th>
            <th style="text-align: center; width: 25%;">@Localizer["Rentals_ColRegisterReturn"]</th>
        </tr>
        </thead>
        <tbody>
        @if(wydane.Any())
        {
        foreach (var item in wydane)
        {
        <tr>
            <td style="font-weight: 600; color: #334155;">@(item.Klient != null ? $"{item.Klient.Nazwisko} {item.Klient.Imie}" : Localizer["Rentals_FallbackClient"].Value)</td>
            <td>@(item.Egzemplarz?.Book?.Tytul ?? Localizer["Common_NoData"].Value)</td>
            <td style="text-align: center; font-family: monospace; font-weight: bold;">#@(item.Egzemplarz?.NumerInwentarzowy ?? "-")</td>
            <td>@item.DataWypozyczenia.ToString("dd.MM.yyyy")</td>
            <td>
                        <span style="@(DateTime.Today > item.DataPlanowanegoZwrotu ? "color: #ef4444; font-weight: bold;" : "color: #16a34a; font-weight: 600;")">
                            @item.DataPlanowanegoZwrotu.ToString("dd.MM.yyyy")
                        </span>
            </td>
            <td style="text-align: center;">
                <form action="/Rentals/ZwrocKsiazke" method="post" style="display: flex; gap: 8px; justify-content: center; margin: 0;">
                    <input type="hidden" name="id_wypozyczenie" value="@item.IdWypozyczenie" />
                    <input type="date" name="data_zwrotu" style="padding: 4px; font-size: 12px; width: 130px;" value="@DateTime.Today.ToString("yyyy-MM-dd")" required>
                    <button type="submit" class="btn-action">@Localizer["Rentals_BtnReturn"]</button>
                </form>
            </td>
        </tr>
        }
        }
        else
        {
        <tr><td colspan="6" style="text-align: center; padding: 20px; color: #94a3b8;">@Localizer["Rentals_AllReturned"]</td></tr>
        }
        </tbody>
    </table>
</div>

<script>
    function toggleAdminOrder(rowId) {
        var element = document.getElementById(rowId);
        if (element.style.display === "none" || element.style.display === "") {
            element.style.display = "table-row";
        } else {
            element.style.display = "none";
        }
    }
</script>
