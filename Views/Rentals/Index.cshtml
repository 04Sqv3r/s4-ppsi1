@model IEnumerable<meow.Models.Wypozyczenie>
@using meow.Services
@{ ViewData["Title"] = Localizer["RentalsIndex_Title"].Value; }
<h2>@Localizer["RentalsIndex_Title"]</h2>

<form method="get" action="/Reports/Index" style="background:#eee; padding:15px; border-radius:4px; display:flex; gap:15px; align-items:flex-end;">
    <div>
        <label style="margin-top:0;">@Localizer["RentalsIndex_From"]</label>
        <input type="date" name="data_od" value="@ViewBag.DataOd" style="width:auto;">
    </div>
    <div>
        <label style="margin-top:0;">@Localizer["RentalsIndex_To"]</label>
        <input type="date" name="data_do" value="@ViewBag.DataDo" style="width:auto;">
    </div>
    <button type="submit" style="margin-top:0;">@Localizer["RentalsIndex_Generate"]</button>
</form>

<table>
    <thead>
    <tr>
        <th>@Localizer["Rentals_ColReader"]</th>
        <th>@Localizer["RentalsIndex_ColTitleCode"]</th>
        <th>@Localizer["RentalsIndex_ColIssueDate"]</th>
        <th>@Localizer["RentalsIndex_ColActualReturn"]</th>
        <th>@Localizer["RentalsIndex_ColDueDate"]</th>
        <th>@Localizer["RentalsIndex_ColDelayDays"]</th>
        <th>@Localizer["RentalsIndex_ColLateFee"]</th>
    </tr>
    </thead>
    <tbody>
    @if (Model.Any())
    {
        @foreach (var row in Model)
        {
            int dniSpoznienia = 0;
            if (row.DataZwrotu.HasValue && row.DataZwrotu.Value.Date > row.DataPlanowanegoZwrotu.Date)
            {
                dniSpoznienia = (row.DataZwrotu.Value.Date - row.DataPlanowanegoZwrotu.Date).Days;
            }
            else if (!row.DataZwrotu.HasValue && DateTime.Today > row.DataPlanowanegoZwrotu.Date)
            {
                dniSpoznienia = (DateTime.Today - row.DataPlanowanegoZwrotu.Date).Days;
            }

            <tr>
                <td>@row.Klient?.Nazwisko @row.Klient?.Imie</td>
                <td>@row.Egzemplarz?.Book?.Tytul <br><small>(@row.Egzemplarz?.NumerInwentarzowy)</small></td>
                <td>@row.DataWypozyczenia.ToString("yyyy-MM-dd")</td>
                <td>@(row.DataZwrotu?.ToString("yyyy-MM-dd") ?? LocalizationHelper.RentalStatus(Localizer, "Wypożyczona"))</td>
                <td>@row.DataPlanowanegoZwrotu.ToString("yyyy-MM-dd")</td>
                <td style="@(dniSpoznienia > 0 ? "color:red; font-weight:bold;" : "")">@dniSpoznienia</td>
                <td>@(row.Platnosc?.Kwota.ToString("F2") ?? "0.00") @Localizer["Common_Currency"]</td>
            </tr>
        }
        <tr class="total-row">
            <td colspan="6" style="text-align: right;">@Localizer["RentalsIndex_TotalRevenue"]</td>
            <td>@ViewBag.SumaGlobalna.ToString("F2") @Localizer["Common_Currency"]</td>
        </tr>
    }
    else
    {
        <tr><td colspan="7" style="text-align:center; padding:30px;">@Localizer["RentalsIndex_NoEntries"]</td></tr>
    }
    </tbody>
</table>
