@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - meow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/responsive.css" rel="stylesheet" />
    <style>
        html, body {
            height: 100%;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f6f9;
            color: #333;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        header {
            background-color: #234465;
            color: white;
            padding: 15px 40px;
        }
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .logo {
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .search-container {
            display: flex;
            flex-grow: 0.5;
            max-width: 600px;
        }
        .search-input {
            width: 100%;
            padding: 10px 15px;
            border: none;
            border-radius: 4px 0 0 4px;
            font-size: 14px;
        }
        .search-btn {
            background-color: #1a3047;
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 0 4px 4px 0;
            cursor: pointer;
            font-weight: bold;
        }
        .search-btn:hover { background-color: #112031; }

        nav {
            display: flex;
            gap: 25px;
            align-items: center;
            font-size: 15px;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 10px;
        }
        nav a {
            color: #e0e0e0;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }
        nav a:hover { color: white; }

        .cart-status {
            background-color: #e67e22;
            color: white;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
        }
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
            flex: 1;
            width: 100%;
            box-sizing: border-box;
        }
        footer {
            background-color: #234465;
            color: rgba(255,255,255,0.7);
            text-align: center;
            padding: 20px;
            margin-top: auto;
            font-size: 14px;
            flex-shrink: 0;
        }

        /* --- STYLE DLA MEGA MENU --- */
        .mega-dropdown {
            position: relative;
            display: inline-block;
        }

        .mega-dropdown-btn {
            cursor: pointer;
        }

        .mega-dropdown-content {
            display: none;
            position: absolute;
            left: 0;
            top: 100%;
            background-color: #ffffff;
            min-width: 850px;
            box-shadow: 0px 8px 24px rgba(0,0,0,0.15);
            border-radius: 6px;
            padding: 25px;
            z-index: 1000;
            gap: 40px;
        }

        /* Niewidoczny mostek — bez tego menu znika w lukę między linkiem a dropdownem */
        .mega-dropdown-content::before {
            content: "";
            position: absolute;
            top: -12px;
            left: 0;
            right: 0;
            height: 12px;
        }

        .mega-dropdown:hover .mega-dropdown-content {
            display: flex;
        }

        .mega-column {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .mega-column h3 {
            font-size: 15px;
            color: #234465;
            margin: 0 0 10px 0;
            font-weight: 700;
            border-bottom: 1px solid #eef2f5;
            padding-bottom: 5px;
        }

        .mega-column a {
            color: #444444 !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: normal;
            padding: 3px 0;
            transition: color 0.15s, padding-left 0.15s;
        }

        .mega-column a:hover {
            color: #e67e22 !important;
            padding-left: 5px;
        }

        .mega-column a.highlight {
            color: #e67e22 !important;
            font-weight: 600;
        }
        .mega-column a.highlight:hover {
            color: #d35400 !important;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-shrink: 0;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .lang-switch {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
            white-space: nowrap;
        }
        .lang-switch a {
            color: #f1c40f !important;
            font-weight: bold;
            text-decoration: none;
        }
        .lang-switch a.active { text-decoration: underline; }
        .lang-switch .sep { color: rgba(255,255,255,0.5); }
        .user-menu {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .user-greeting {
            font-size: 14px;
            white-space: nowrap;
        }

        .search-wrapper { position: relative; flex-grow: 0.5; max-width: 600px; }
        #search-results {
            display: none;
            position: absolute;
            top: 100%;
            left: 0; right: 0;
            background: white;
            border-radius: 0 0 6px 6px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            z-index: 2000;
            max-height: 320px;
            overflow-y: auto;
        }
        .search-result-item {
            display: block;
            padding: 10px 14px;
            color: #333 !important;
            text-decoration: none;
            border-bottom: 1px solid #eee;
        }
        .search-result-item:hover { background: #f8fafc; }
        .search-result-item span { display: block; font-size: 12px; color: #64748b; }
    </style>
</head>
<body>

<header>
    @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor
    @{
        var sessionUser = HttpContextAccessor.HttpContext?.Session.GetString("User");
        var sessionRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");

        var koszykString = HttpContextAccessor.HttpContext?.Session.GetString("Koszyk") ?? "";
        int iloscWKoszyku = string.IsNullOrEmpty(koszykString) 
            ? 0 
            : koszykString.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
            
   
        var sessionAuthError = HttpContextAccessor.HttpContext?.Session.GetString("MeowAuthError");
        var cultureReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
        var roleLabel = sessionRole == "Admin"
            ? Localizer["Role_Admin"].Value
            : Localizer["Role_Klient"].Value;
        var isPl = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "pl";
    }

    <div class="header-top">
        @if (sessionRole == "Admin")
        {
            <a href="/" class="logo" style="text-decoration: none; color: white;"> @Localizer["Admin_PanelTitle"] 🐾</a>
        }
        else
        {
            <a href="/Shop" class="logo" style="text-decoration: none; color: white;"> @Localizer["Nav_LogoShop"] 🐾</a>
        }

        @if (sessionRole != "Admin")
        {
            <div class="search-wrapper">
                <form action="/Shop" method="get" class="search-container" style="max-width:100%;">
                    <input type="text"
                           id="global-search"
                           name="fraza"
                           value="@ViewBag.WybranaFraza"
                           class="search-input"
                           data-no-results="@Localizer["Search_NoResults"]"
                           placeholder="@Localizer["Search_Placeholder"] 🐾"
                           autocomplete="off">
                    @if (!string.IsNullOrEmpty(ViewBag.AktualnyGatunek))
                    {
                        <input type="hidden" name="gatunek" value="@ViewBag.AktualnyGatunek" />
                    }
                    <button type="submit" class="search-btn">@Localizer["Nav_Search"]</button>
                </form>
                <div id="search-results"></div>
            </div>
        }
        else
        {
            <div style="flex-grow: 0.5;"></div>
        }

        <div class="header-actions">
            <div class="lang-switch">
                <a href="@Url.Action("Set", "Culture", new { culture = "pl", returnUrl = cultureReturnUrl })" class="@(isPl ? "active" : "")">PL</a>
                <span class="sep">|</span>
                <a href="@Url.Action("Set", "Culture", new { culture = "en", returnUrl = cultureReturnUrl })" class="@(!isPl ? "active" : "")">EN</a>
            </div>
            @if (sessionUser != null)
            {
                <div class="user-menu">
                    <span class="user-greeting">@string.Format(Localizer["Nav_WelcomeUser"].Value, sessionUser, roleLabel)</span>
                    @if (sessionRole != "Admin")
                    {
                        <a href="/Account/Profile" style="color: #f1c40f; text-decoration: none; font-weight: bold;">👤 @Localizer["Nav_Profile"]</a>
                    }
                    <a href="/Account/Logout" style="color: #ff6b6b; text-decoration: none; font-weight: bold;">@Localizer["Nav_Logout"]</a>
                </div>
            }
            else
            {
                <a href="/Account/Login" style="color: white; text-decoration: none; font-weight: bold;">@Localizer["Nav_Login"]</a>
                <a href="/Account/Register" style="color: #f39c12; text-decoration: none; font-weight: bold;">@Localizer["Nav_Register"]</a>
            }
        </div>
    </div>

    <nav>
        @if (sessionRole == "Admin")
        {
            <a href="/" style="font-weight: bold; color: #f1c40f;">🏠 @Localizer["Admin_Nav_Dashboard"]</a>
            <a href="/Books/Create" style="color: #f1c40f; font-weight: bold;">@Localizer["Admin_Nav_AddBooks"]</a>
            <a href="/Books" style="color: #f1c40f;">@Localizer["Admin_Nav_Inventory"]</a>
            <a href="/Rentals/Returns" style="color: #f1c40f; font-weight: bold;">@Localizer["Admin_Nav_OrdersRentals"]</a>
        }
        else
        {
            <a href="/" style="font-weight: bold; color: #f1c40f;">🏠 @Localizer["Nav_Home"]</a>

            <div class="mega-dropdown" id="mega-menu">
                <span class="mega-dropdown-btn" id="mega-menu-btn">@Localizer["Nav_Categories"] ▾</span>
                <div class="mega-dropdown-content">
                    @await Html.PartialAsync("_MegaMenu")
                </div>
            </div>
            
            
            <div style="margin-left: auto; display: flex; gap: 25px; align-items: center;">
                <a href="/Shop/Cart">🛒 @Localizer["Nav_Cart"] <span class="cart-status">@iloscWKoszyku</span></a>
            </div>
        }
    </nav>
</header>

<div class="container">
    @if (!string.IsNullOrEmpty(sessionAuthError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
            <span>@sessionAuthError</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="background: none; border: none; font-size: 16px; cursor: pointer; color: inherit;" onclick="this.parentElement.style.display='none';">×</button>
        </div>
        
        HttpContextAccessor.HttpContext?.Session.Remove("MeowAuthError");
    }

    @if (TempData["Message"] != null)
    {
        var alertClass = TempData["MessageType"]?.ToString() == "success" ? "alert-success" : 
            (TempData["MessageType"]?.ToString() == "warning" ? "alert-warning" : "alert-danger");
                     
        <div class="alert @alertClass alert-dismissible fade show" role="alert" style="padding: 12px 20px; margin-bottom: 20px; border-radius: 6px; font-size: 14px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; background-color: @(alertClass == "alert-success" ? "#d1e7dd" : (alertClass == "alert-warning" ? "#fff3cd" : "#f8d7da")); color: @(alertClass == "alert-success" ? "#0f5132" : (alertClass == "alert-warning" ? "#664d03" : "#842029")); border: 1px solid @(alertClass == "alert-success" ? "#badbcc" : (alertClass == "alert-warning" ? "#ffecb5" : "#f5c2c7"));">
            <span>@TempData["Message"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="background: none; border: none; font-size: 16px; cursor: pointer; color: inherit;" onclick="this.parentElement.style.display='none';">×</button>
        </div>
    }
    
    @RenderBody()
</div>

<footer>
    &copy; @DateTime.Now.Year @Localizer["Footer_Text"]
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/live-search.js"></script>
<script>
    (function () {
        var btn = document.getElementById('mega-menu-btn');
        var menu = document.getElementById('mega-menu');
        if (btn && menu) {
            btn.addEventListener('click', function (e) {
                if (window.innerWidth <= 992) {
                    e.preventDefault();
                    menu.classList.toggle('open');
                }
            });
        }
    })();
</script>
</body>
</html>