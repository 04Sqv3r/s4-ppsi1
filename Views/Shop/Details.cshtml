@model meow.Models.Book
@{
    ViewData["Title"] = Model.Tytul;
}

<style>
    .product-page {
        display: flex;
        gap: 50px;
        background: #ffffff;
        padding: 40px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-top: 20px;
    }

    .product-cover-section {
        flex: 1;
        max-width: 400px;
        text-align: center;
    }

    .product-cover {
        width: 100%;
        max-height: 550px;
        object-fit: cover;
        border-radius: 6px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

    .product-info-section {
        flex: 1.5;
        display: flex;
        flex-direction: column;
    }

    .product-breadcrumbs {
        font-size: 13px;
        color: #777;
        margin-bottom: 15px;
    }

    .btn-buy {
        background-color: #e67e22;
        color: white;
        border: none;
        padding: 14px 35px;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        transition: background-color 0.2s;
        text-align: center;
        text-decoration: none;
        display: inline-block;
    }

    .btn-buy:hover {
        background-color: #d35400;
    }

    .btn-reserve {
        background-color: #f1c40f;
        color: #234465;
        border: none;
        padding: 12px 24px;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        transition: background-color 0.2s;
    }

    .btn-reserve:hover {
        background-color: #f39c12;
    }
</style>

<div class="product-breadcrumbs">
    @Localizer["Common_Books"] &gt; @Model.Gatunek &gt; @Model.Tytul
</div>

<div class="product-page">

    <div class="product-cover-section">
        @{
            var detailCoverFallback = $"https://placehold.co/400x550/234465/ffffff?font=source-sans-pro&text={Uri.EscapeDataString(Model.Tytul.Length > 24 ? Model.Tytul[..24] : Model.Tytul)}";
        }
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="product-cover" alt="@Localizer["Details_CoverAlt"] @Model.Tytul"
                 data-fallback="@detailCoverFallback"
                 onerror="this.onerror=null;this.src=this.dataset.fallback;" />
        }
        else
        {
            <img src="@detailCoverFallback" class="product-cover" alt="@Localizer["Details_CoverPlaceholder"]" />
        }
    </div>

    <div class="product-info-section">
        <h1 style="font-size: 28px; color: #1e293b; margin: 0 0 5px 0; font-weight: 600;">@Model.Tytul</h1>
        <div style="font-size: 20px; color: #334155; font-weight: 400; margin-bottom: 25px;">@Model.Autor</div>

        <div class="price-container" style="margin-bottom: 25px;">
            @if (Model.Cena > 0)
            {
                <div style="font-size: 42px; font-weight: 700; color: #1e293b; letter-spacing: -0.5px; margin-bottom: 8px;">
                    @Model.Cena.Value.ToString("F2") @Localizer["Common_Currency"]
                </div>

                @if (Model.CenaOkladkowa > Model.Cena)
                {
                    int rabatProcent = (int)Math.Round((double)((Model.CenaOkladkowa - Model.Cena) / Model.CenaOkladkowa * 100));

                    <div style="font-size: 15px; color: #64748b; display: flex; align-items: center; gap: 8px;">
                        <span>@Localizer["Details_CoverPrice"] @Model.CenaOkladkowa.Value.ToString("F2") @Localizer["Common_Currency"]</span>
                        <span style="background: #fee2e2; color: #ef4444; padding: 2px 6px; border-radius: 4px; font-weight: bold; font-size: 12px;">
                            @string.Format(Localizer["Details_SavePercent"].Value, rabatProcent)
                        </span>
                    </div>
                }
            }
            else
            {
                <div style="font-size: 24px; color: #64748b; font-weight: 600;">@Localizer["Details_RentOnly"]</div>
            }
        </div>

        <div class="purchase-actions" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 6px; margin-bottom: 20px;">
            @if (Model.Cena > 0)
            {
                if (Model.IloscDoSprzedazy > 0)
                {
                    <div style="color: #16a34a; font-weight: 600; font-size: 14px; margin-bottom: 12px;">
                        @string.Format(Localizer["Details_InStock"].Value, Model.IloscDoSprzedazy)
                    </div>

                    <form action="/Shop/AddToCart" method="post" style="margin: 0;">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn-buy">
                            @Localizer["Details_AddToCart"]
                        </button>
                    </form>
                }
                else
                {
                    <div style="color: #16a34a; font-weight: 600; font-size: 14px;">@Localizer["Details_SoldOut"]</div>
                }
            }
            else
            {
                <div style="color: #64748b; font-weight: 500; font-size: 14px;">@Localizer["Details_FreeLibrary"]</div>
            }

            @if (TempData["Message"] != null)
            {
                var msgType = TempData["MessageType"]?.ToString();
                var bgColor = msgType == "success" ? "#dcfce7" : "#fee2e2";
                var textColor = msgType == "success" ? "#15803d" : "#ef4444";
    
                <div style="padding: 15px; background: @bgColor; color: @textColor; border-radius: 6px; margin: 15px 0; font-weight: bold; border: 1px solid @textColor;">
                    @TempData["Message"]
                </div>
            }
        </div>

        <div class="library-box" style="padding: 15px; background: #f8fafc; border-radius: 6px; border-left: 4px solid #234465; margin-bottom: 20px;">
            <h4 style="margin: 0 0 5px 0; color: #234465; font-size: 14px; font-weight: 700;">@Localizer["Details_StationaryTitle"]</h4>
            <div style="font-size: 13px; color: #475569;">
                @Localizer["Details_OnShelves"] <strong>@Model.IloscEgzemplarzy @Localizer["Common_Pcs"]</strong> | @Localizer["Details_AvailableRent"]
                <strong style="color: @(ViewBag.DostepneDoWypozyczenia > 0 ? "#16a34a" : "#dc2626")">@ViewBag.DostepneDoWypozyczenia @Localizer["Common_Pcs"]</strong>
            </div>
        </div>

        <div class="reservation-actions" style="background: #ffffff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 6px;">
            <form action="/Rentals/Zarezerwuj" method="post" style="margin: 0;">
                @if (ViewBag.WolneEgzemplarze != null && ((List<meow.Models.Egzemplarz>)ViewBag.WolneEgzemplarze).Any())
                {
                    <div style="margin-bottom: 12px;">
                        <label style="display: block; font-size: 14px; font-weight: 600; color: #334155; margin-bottom: 5px;">
                            @Localizer["Details_SelectCopy"]
                        </label>
                        <select name="idEgzemplarza" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 4px; font-size: 14px; background: #f8fafc;" required>
                            @foreach (var e in (List<meow.Models.Egzemplarz>)ViewBag.WolneEgzemplarze)
                            {
                                <option value="@e.IdEgzemplarza">
                                    @Localizer["Details_CopyState"] @meow.Services.LocalizationHelper.CopyCondition(Localizer, e.Stan) (@e.NumerInwentarzowy)
                                </option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn-reserve">
                        @Localizer["Details_ReserveBtn"]
                    </button>
                }
                else
                {
                    <div style="background: #f1f5f9; color: #475569; padding: 12px; border-radius: 4px; text-align: center; font-size: 14px; font-weight: 500;">
                        @Localizer["Details_NoCopies"]
                    </div>
                }
            </form>
        </div>

    </div>
</div>

<div style="background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 30px;">
    <h3 style="color: #234465; font-size: 20px; margin-top: 0; margin-bottom: 15px; font-weight: 700; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px;">@Localizer["Details_DescTitle"]</h3>
    <p style="font-size: 15px; line-height: 1.7; color: #334155; white-space: pre-line; margin: 0;">
        @(string.IsNullOrEmpty(Model.Opis) ? Localizer["Details_NoDesc"].Value : Model.Opis)
    </p>
</div>

<div style="background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 30px; font-family: sans-serif;">
    <h3 style="color: #234465; font-size: 20px; margin-top: 0; margin-bottom: 20px; font-weight: 700; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px;">@Localizer["Details_SpecTitle"]</h3>

    <div style="max-width: 600px;">
        <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b; width: 40%;">@Localizer["Details_ProductId"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Model.Id</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_LabelTitle"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Model.Tytul</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_OriginalTitle"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(string.IsNullOrEmpty(Model.TytulOryginalny) ? Localizer["Common_None"].Value : Model.TytulOryginalny)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Series"]</td>
                <td style="padding: 10px 0; color: #234465; font-weight: 600; text-decoration: underline;">@(string.IsNullOrEmpty(Model.Seria) ? Localizer["Common_None"].Value : Model.Seria)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Author"]</td>
                <td style="padding: 10px 0; color: #234465; font-weight: 600; text-decoration: underline;">@Model.Autor</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Translation"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(string.IsNullOrEmpty(Model.Tlumaczenie) ? Localizer["Common_NoData"].Value : Model.Tlumaczenie)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Publisher"]</td>
                <td style="padding: 10px 0; color: #234465; font-weight: 600; text-decoration: underline;">@(string.IsNullOrEmpty(Model.Wydawnictwo) ? Localizer["Common_NoData"].Value : Model.Wydawnictwo)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_EditionLang"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Model.JezykWydania</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_OriginalLang"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(string.IsNullOrEmpty(Model.JezykOryginalu) ? Localizer["Common_NoData"].Value : Model.JezykOryginalu)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Pages"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.LiczbaStron.HasValue ? Model.LiczbaStron.Value.ToString() : Localizer["Common_NoData"].Value)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_EditionNum"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Model.NumerWydania</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Premiere"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.DataPremiery.HasValue ? Model.DataPremiery.Value.ToString("yyyy-MM-dd") : Localizer["Common_NoData"].Value)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_PubYear"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Model.RokWydania</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_PubDate"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.DataWydania.HasValue ? Model.DataWydania.Value.ToString("yyyy-MM-dd") : Localizer["Common_NoData"].Value)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Format"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@Localizer["Details_FormatBook"]</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_CoverType"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(string.IsNullOrEmpty(Model.OkladkaTyp) ? Localizer["Common_NoData"].Value : Model.OkladkaTyp)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Height"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.WysokoscMm.HasValue ? Model.WysokoscMm.Value.ToString() : Localizer["Common_None"].Value)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Depth"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.GlebokoscMm.HasValue ? Model.GlebokoscMm.Value.ToString() : Localizer["Common_None"].Value)</td>
            </tr>
            <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_Width"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500;">@(Model.SzerokoscMm.HasValue ? Model.SzerokoscMm.Value.ToString() : Localizer["Common_None"].Value)</td>
            </tr>
            <tr style="border-bottom: none;">
                <td style="padding: 10px 0; color: #64748b;">@Localizer["Details_EAN"]</td>
                <td style="padding: 10px 0; color: #1e293b; font-weight: 500; font-family: monospace; font-size: 15px;">@(string.IsNullOrEmpty(Model.EAN) ? Localizer["Common_NoData"].Value : Model.EAN)</td>
            </tr>
        </table>
    </div>
</div>
