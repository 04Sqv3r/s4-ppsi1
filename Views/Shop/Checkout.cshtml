@using Microsoft.AspNetCore.Http
@model meow.Models.Klient
@{
    ViewData["Title"] = Localizer["Checkout_Title"];
}

<style>
    .checkout-container {
        display: flex;
        gap: 30px;
        margin-top: 30px;
        font-family: sans-serif;
    }

    .checkout-form-section {
        flex: 2;
        background: #ffffff;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .checkout-summary-section {
        flex: 1;
        align-self: flex-start;
    }

    .summary-box {
        background: #ffffff;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .form-group-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-field {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .form-field label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 6px;
        font-weight: 500;
    }

    .form-field input, .form-field select {
        padding: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        font-size: 14px;
        outline: none;
        color: #1e293b;
    }

    .form-field input:focus {
        border-color: #ff5a00;
    }

    .btn-submit-order {
        background-color: #ff5a00;
        color: white;
        border: none;
        padding: 14px;
        width: 100%;
        font-size: 16px;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        text-align: center;
        transition: background-color 0.2s;
    }

    .btn-submit-order:hover {
        background-color: #e04f00;
    }

    .radio-group {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
        font-size: 14px;
        font-weight: 500;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 14px;
        color: #64748b;
        margin-bottom: 12px;
    }
</style>

<div style="border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; font-size: 14px; color: #94a3b8; font-weight: 500; margin-top: 10px;">
    <span style="color: #64748b;">@Localizer["Checkout_StepCart"]</span> &nbsp;➔&nbsp; 
    <span style="color: #ff5a00; font-weight: bold; border-bottom: 2px solid #ff5a00; padding-bottom: 15px;">@Localizer["Checkout_StepPayment"]</span> &nbsp;➔&nbsp; 
    <span>@Localizer["Checkout_StepDelivery"]</span> &nbsp;➔&nbsp; 
    <span>@Localizer["Checkout_StepDone"]</span>
</div>

@if (Context.Session.GetString("User") == null)
{
    <div style="background: white; padding: 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); text-align: center; margin-top: 30px;">
        <h2 style="color: #1e293b; margin-bottom: 15px;">@Localizer["Checkout_LoginTitle"]</h2>
        <p style="color: #64748b; margin-bottom: 25px;">@Localizer["Checkout_LoginDesc"]</p>
        <a href="/Account/Login?returnUrl=/Shop/Checkout" style="background: #ff5a00; color: white; padding: 12px 30px; text-decoration: none; font-weight: bold; border-radius: 4px; display: inline-block;">
            @Localizer["Checkout_LoginBtn"]
        </a>
    </div>
}
else
{
    <form action="/Shop/Delivery" method="post">
        <div class="checkout-container">
            
            <div class="checkout-form-section">
                <h2 style="font-size: 22px; color: #1e293b; margin-top: 0; margin-bottom: 20px; font-weight: 700;">@Localizer["Checkout_RecipientTitle"]</h2>
                
                <div class="radio-group">
                    <label><input type="radio" name="typ_odbiorcy" value="prywatna" id="radioPrywatna" onchange="toggleFormLayout()" checked> @Localizer["Checkout_TypePrivate"]</label>
                    <label><input type="radio" name="typ_odbiorcy" value="firma" id="radioFirma" onchange="toggleFormLayout()"> @Localizer["Checkout_TypeCompany"]</label>
                </div>

                <div class="form-group-row">
                    <div class="form-field">
                        <label id="labelImie">@Localizer["Checkout_FirstName"]</label>
                        <input type="text" name="imie" value="@Model?.Imie" 
                               pattern="^[A-Za-zŻżÓóŁłĆćĘęŚśĄąŹźŃń\s]+$" 
                               title="Imię może zawierać wyłącznie litery!" required />
                    </div>

                    <div class="form-field" id="groupNazwisko">
                        <label>@Localizer["Checkout_LastName"]</label>
                        <input type="text" name="nazwisko" id="inputNazwisko" value="@Model?.Nazwisko" 
                               pattern="^[A-Za-zŻżÓóŁłĆćĘęŚśĄąŹźŃń\s-]+$" 
                               title="Nazwisko może zawierać wyłącznie litery lub łącznik (myślnik)!" required />
                    </div>
                </div>

                <div class="form-group-row" id="groupFirmaPola" style="display: none;">
                    <div class="form-field">
                        <label>@Localizer["Checkout_CompanyName"]</label>
                        <input type="text" name="nazwa_firmy" id="inputNazwaFirmy" />
                    </div>
                    <div class="form-field">
                        <label>@Localizer["Checkout_NIP"]</label>
                        <input type="text" name="nip" id="inputNip" maxlength="10" 
                               pattern="^[0-9]{10}$" title="NIP musi składać się z dokładnie 10 cyfr!" placeholder="np. 1234567890" />
                    </div>
                </div>

                <div class="form-group-row">
                    <div class="form-field">
                        <label>@Localizer["Checkout_Email"]</label>
                        <input type="email" name="email" value="@Model?.Email" required />
                    </div>
                    <div class="form-field">
                        <label>@Localizer["Checkout_Phone"]</label>
                        <input type="text" name="telefon" value="@Model?.Telefon" 
                               pattern="^[0-9\+]{9,15}$" title="Wpisz poprawny numer telefonu!" placeholder="+48" required />
                    </div>
                </div>

                <div class="form-group-row">
                    <div class="form-field">
                        <label>@Localizer["Checkout_Country"]</label>
                        <select name="kraj">
                            <option value="Polska">@Localizer["Checkout_Country_PL"]</option>
                            <option value="Niemcy">@Localizer["Checkout_Country_DE"]</option>
                            <option value="Czechy">@Localizer["Checkout_Country_CZ"]</option>
                        </select>
                    </div>
                    <div class="form-field" style="flex: 2;">
                        <label>@Localizer["Checkout_Street"]</label>
                        <input type="text" name="ulica" required />
                    </div>
                </div>

                <div class="form-group-row">
                    <div class="form-field">
                        <label>@Localizer["Checkout_Building"]</label>
                        <input type="text" name="numer" required />
                    </div>
                    <div class="form-field">
                        <label>@Localizer["Checkout_Unit"]</label>
                        <input type="text" name="lokal" />
                    </div>
                </div>

                <div class="form-group-row">
                    <div class="form-field">
                        <label>@Localizer["Checkout_Postal"]</label>
                        <input type="text" name="kodPocztowy" id="inputKodPocztowy" maxlength="6" 
                               pattern="^[0-9]{2}-[0-9]{3}$" title="Wpisz kod pocztowy w formacie 00-000!" placeholder="00-000" required />
                    </div>
                    <div class="form-field" style="flex: 2;">
                        <label>@Localizer["Checkout_City"]</label>
                        <input type="text" name="miejscowosc" 
                               pattern="^[A-Za-zŻżÓóŁłĆćĘęŚśĄąŹźŃń\s-]+$" 
                               title="Nazwa miejscowości nie może zawierać cyfr ani znaków specjalnych!" required />
                    </div>
                </div>
            </div>

            <div class="checkout-summary-section">
                <div class="summary-box">
                    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 20px;">
                        <span style="font-size: 18px; font-weight: 700; color: #1e293b;">@Localizer["Checkout_CartValue"]</span>
                        <span style="font-size: 24px; font-weight: 700; color: #1e293b;">@(((decimal)ViewBag.WartoscKoszyka).ToString("F2")) @Localizer["Common_Currency"]</span>
                    </div>

                    <div class="summary-row">
                        <span>@Localizer["Checkout_ProductsValue"]</span>
                        <span>@(((decimal)ViewBag.WartoscProduktow).ToString("F2")) @Localizer["Common_Currency"]</span>
                    </div>
                    <div class="summary-row" style="border-bottom: 1px solid #f1f5f9; padding-bottom: 15px; margin-bottom: 20px;">
                        <span>@Localizer["Checkout_DeliveryCost"]</span>
                        <span style="color: #64748b; font-weight: 500;">@Localizer["Checkout_DeliveryLater"]</span>
                    </div>

                    <button type="submit" class="btn-submit-order">
                        @Localizer["Checkout_NextDelivery"]
                    </button>
                </div>
            </div>

        </div>
    </form>

    <script>
        var labels = { firstName: '@Localizer["Checkout_FirstName"]', contactFirstName: '@Localizer["Checkout_ContactFirstName"]' };

        function toggleFormLayout() {
            var isFirma = document.getElementById("radioFirma").checked;
            var groupNazwisko = document.getElementById("groupNazwisko");
            var groupFirmaPola = document.getElementById("groupFirmaPola");
            var inputNazwisko = document.getElementById("inputNazwisko");
            var inputNazwaFirmy = document.getElementById("inputNazwaFirmy");
            var inputNip = document.getElementById("inputNip");
            var labelImie = document.getElementById("labelImie");

            if (isFirma) {
                groupNazwisko.style.display = "none";
                groupFirmaPola.style.display = "flex";
                labelImie.innerText = labels.contactFirstName;
                
                inputNazwisko.value = "";
                inputNazwisko.required = false;
                
                inputNazwaFirmy.required = true;
                inputNip.required = true;
            } else {
                groupNazwisko.style.display = "flex";
                groupFirmaPola.style.display = "none";
                labelImie.innerText = labels.firstName;
                
                inputNazwaFirmy.value = "";
                inputNip.value = "";
                
                inputNazwisko.required = true;
                inputNazwaFirmy.required = false;
                inputNip.required = false;
            }
        }

        document.getElementById("inputKodPocztowy").addEventListener("input", function (e) {
            var value = e.target.value.replace(/\D/g, "");
            if (value.length > 2) {
                e.target.value = value.substring(0, 2) + "-" + value.substring(2, 5);
            } else {
                e.target.value = value;
            }
        });

        window.onload = toggleFormLayout;
    </script>
}
